{
    "name": "backend",
    "version": "1.0.0",
    "description": "API de Gerenciamento de Pedidos com Estoque Atômico",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:seed": "npx sequelize-cli db:seed:all",
        "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:undo:all && npx sequelize-cli db:seed:all"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@11.0.0-alpha.11",
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-async-errors": "^3.1.1",
        "pg": "^8.19.0",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.37.7"
    },
    "devDependencies": {
        "nodemon": "^3.1.9",
        "sequelize-cli": "^6.6.5"
    }
}
